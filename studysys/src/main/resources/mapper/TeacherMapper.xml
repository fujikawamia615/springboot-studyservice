<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hdd.studysys.mapper.TeacherMapper">
    <select id="selectAll" resultType="com.hdd.studysys.entity.Teacher"> select * from t_teacher </select>
    <select id="selectById" resultType="com.hdd.studysys.entity.Teacher"> SELECT * FROM t_teacher
        WHERE teacher_id = #{id} </select>
    <insert id="insert" parameterType="com.hdd.studysys.entity.Teacher"> INSERT INTO
        t_teacher(teacher_id,teacher_name,department_id)
        VALUES(#{teacherId},#{teacherName},#{departmentId}) </insert>
    <update id="update" parameterType="com.hdd.studysys.entity.Teacher"> UPDATE t_teacher SET
        teacher_name = #{teacherName},department_id = #{departmentId} WHERE teacher_id =
        #{teacherId} </update>
    <delete id="deleteById" parameterType="int"> DELETE FROM t_teacher WHERE teacher_id = #{id} </delete>
    <select id="search" resultType="com.hdd.studysys.entity.Teacher"> select * from t_teacher <where>
            <if test="teacherName != null and teacherName != ''"> and teacher_name like '%' ||
        #{teacherName} || '%' </if>
    <if test="departmentId != null"> and department_id =
        #{departmentId} </if>
        </where>
    </select>
</mapper>