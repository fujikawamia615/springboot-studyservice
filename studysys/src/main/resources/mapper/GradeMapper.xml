<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hdd.studysys.mapper.GradeMapper">
    <select id="selectAll" resultType="com.hdd.studysys.entity.Grade"> SELECT * FROM t_grade </select>
    <select id="selectById" resultType="com.hdd.studysys.entity.Grade"> SELECT * FROM t_grade WHERE
        grade_id = #{id} </select>
    <insert id="insert" parameterType="com.hdd.studysys.entity.Grade" useGeneratedKeys="true"
        keyProperty="gradeId" keyColumn="grade_id"> INSERT INTO t_grade(student_id,course_id,grade)
        VALUES(#{studentId},#{courseId},#{grade}) </insert>
    <update id="update" parameterType="com.hdd.studysys.entity.Grade"> UPDATE t_grade SET student_id
        = #{studentId},course_id = #{courseId},grade = #{grade} WHERE grade_id = #{gradeId} </update>
    <delete id="deleteById" parameterType="int"> DELETE FROM t_grade WHERE grade_id = #{id} </delete>
    <select id="search" resultType="com.hdd.studysys.entity.Grade"> SELECT * FROM t_grade <where>
            <if test="studentId != null"> and student_id = #{studentId} </if>
            <if test="courseId != null"> and course_id = #{courseId} </if>
            <if test="grade != null"> and grade = #{grade} </if>
        </where>
    </select>
</mapper>